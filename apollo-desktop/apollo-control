#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Apollo Linux — Apollo Control Center
Settings hub for Apollo Desktop: appearance, display, effects, drivers.

Sections:
  - Appearance  (theme, icons, fonts, cursors)
  - Display     (resolution, DPI, monitors)
  - Effects     (blur, shadows, animations, transparency)
  - Desktop     (wallpaper, panel layout)
  - Drivers     (GPU driver info, DKMS status)
  - About       (Apollo Linux version, hardware)
"""

import os
import subprocess
import json
import sys

try:
    import gi
    gi.require_version("Gtk", "4.0")
    gi.require_version("Adw", "1")
    from gi.repository import Gtk, Adw, GLib, Gdk, GdkPixbuf, Pango
except ImportError:
    print("ERROR: GTK4 / libadwaita required.", file=sys.stderr)
    sys.exit(1)

CONFIG_DIR  = os.path.expanduser("~/.config/apollo")
SHELL_CFG   = os.path.expanduser("~/.config/apollo-shell/apollo-shell.json")
PICOM_CFG   = os.path.expanduser("~/.config/picom/picom.conf")
GTK3_CFG    = os.path.expanduser("~/.config/gtk-3.0/settings.ini")
DPI_FILE    = os.path.join(CONFIG_DIR, "dpi")
WALLPAPER_FILE = os.path.join(CONFIG_DIR, "wallpaper")
WALLPAPER_DIR  = "/usr/share/apollo/wallpapers"

CSS = b"""
