--- a/kernel/nvidia/nv-linux.h
+++ b/kernel/nvidia/nv-linux.h
@@ -1,6 +1,11 @@
 /* SPDX-License-Identifier: GPL-2.0 */
 #ifndef _NV_LINUX_H_
 #define _NV_LINUX_H_
+
+/* Apollo Linux: include unified kernel compatibility shims */
+#include "apollo-nvidia-compat.h"
+
 #include <linux/version.h>
 #include <linux/module.h>
 #include <linux/kernel.h>

--- a/kernel/nvidia-drm/nvidia-drm-drv.c
