@@ -1,6 +1,7 @@
 #include "nvidia-drm-drv.h"
 #include "nvidia-drm-gem.h"
+#include "apollo-nvidia-compat.h"

 /* Kernel 6.13+: gem_prime_import_sg_table removed from drm_driver struct */
 #if defined(NV_DRM_PRIME_SG_NO_CALLBACK)
@@ -80,10 +81,20 @@ static struct drm_driver nv_drm_driver = {
     .gem_free_object_unlocked = nv_drm_gem_free_object,
     .prime_handle_to_fd       = drm_gem_prime_handle_to_fd,
     .prime_fd_to_handle       = drm_gem_prime_fd_to_handle,
