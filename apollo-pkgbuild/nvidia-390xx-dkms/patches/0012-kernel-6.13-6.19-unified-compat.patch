--- a/kernel/nvidia/os-mem.c
+++ b/kernel/nvidia/os-mem.c
@@ -1,4 +1,5 @@
 #include "nv-linux.h"
+#include "apollo-nvidia-compat.h"

 /* Kernel 6.14+: mmap_sem removed, use mmap_lock */
 static int nv_mmap_read_lock_wrapper(struct mm_struct *mm)
@@ -10,7 +11,11 @@ static int nv_mmap_read_lock_wrapper(struct mm_struct *mm)
 #if defined(NV_USE_FOLIO_PFN)
     /* Use folio-aware path */
     return 0;
+#elif defined(down_read_mmap_sem)
+    down_read_mmap_sem(mm);
+    return 1;
 #else
     mmap_read_lock(mm);
     return 1;
 #endif
 }

--- a/kernel/nvidia/nv-procfs.c
+++ b/kernel/nvidia/nv-procfs.c
@@ -1,4 +1,5 @@
 #include "nv-linux.h"
+#include "apollo-nvidia-compat.h"

 /* Kernel 6.15+: PDE_DATA() macro removed */
 static void *nv_proc_seq_start(struct seq_file *s, loff_t *pos)
 {
-    return PDE_DATA(file_inode(s->file));
+#if defined(PDE_DATA)
+    return PDE_DATA(file_inode(s->file));
+#else
+    return pde_data(file_inode(s->file));
+#endif
 }

