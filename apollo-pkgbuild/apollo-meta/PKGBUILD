# Maintainer: Apollo Linux Team <dev@apollolinux.org>
#
# apollo-meta — Meta-package that brings in the complete Apollo Desktop
#
# Installing this single package pulls in the full Apollo Linux desktop stack.
# Used by Calamares during installation to ensure all components are present.

pkgname=apollo-meta
pkgver=1.0
pkgrel=1
pkgdesc="Apollo Linux — complete desktop meta-package"
arch=('any')
url="https://github.com/strayfodanator/apollolinux"
license=('GPL-2.0')
depends=(
    # ── Core desktop components ───────────────────────────────────
    'apollo-openbox'          # Window manager (fork)
    'apollo-themes'           # GTK/Openbox/wallpaper theme bundle
    'apollo-shell-pkg'        # QuickShell panels + widgets + plugins
    'apollo-apps'             # Welcome, Control Center, session menu

    # ── Display manager ────────────────────────────────────────────
    'lightdm'
    'lightdm-gtk-greeter'

    # ── Compositor ────────────────────────────────────────────────
    'picom'

    # ── Notifications ─────────────────────────────────────────────
    'dunst'

    # ── File manager ──────────────────────────────────────────────
    'thunar'
    'thunar-volman'
    'gvfs'
    'gvfs-smb'
    'gvfs-mtp'

    # ── Terminal ──────────────────────────────────────────────────
    'alacritty'

    # ── App launcher ──────────────────────────────────────────────
    'ulauncher'

    # ── Audio (PipeWire stack) ────────────────────────────────────
    'pipewire'
    'pipewire-pulse'
    'pipewire-alsa'
    'wireplumber'
    'pavucontrol'

    # ── Network ───────────────────────────────────────────────────
    'networkmanager'
    'network-manager-applet'

    # ── Bluetooth ─────────────────────────────────────────────────
    'bluez'
    'bluez-utils'
    'blueman'

    # ── Fonts ─────────────────────────────────────────────────────
    'ttf-firacode-nerd'
    'noto-fonts'
    'noto-fonts-emoji'

    # ── Icons & cursors ───────────────────────────────────────────
    'papirus-icon-theme'
    'bibata-cursor-theme'

    # ── Qt theming ────────────────────────────────────────────────
    'qt5ct'
    'qt6ct'
    'kvantum'

    # ── Polkit ────────────────────────────────────────────────────
    'polkit-gnome'

    # ── Screenshot ────────────────────────────────────────────────
    'xfce4-screenshooter'

    # ── Editor ────────────────────────────────────────────────────
    'kate'

    # ── Plymouth (boot splash) ────────────────────────────────────
    'plymouth'

    # ── Arch tools ────────────────────────────────────────────────
    'xdg-utils'
    'xdg-user-dirs'
    'bash-completion'
)
optdepends=(
    'hyprland: Wayland compositor (modern GPU only)'
    'hyprlock: Wayland screen locker'
    'hypridle: Wayland idle management'
    'hyprpaper: Wayland wallpaper daemon'
    'xdg-desktop-portal-hyprland: Hyprland portal'
    'steam: Gaming platform'
    'lutris: Game manager'
    'gamemode: Gaming performance mode'
)
provides=('apollo-desktop')
