# Maintainer: Apollo Linux Team <dev@apollolinux.org>
#
# apollo-themes — Official Apollo Linux theme bundle
# Installs: GTK3/4 theme, Openbox theme, wallpapers, icons overrides, cursors meta

pkgname=apollo-themes
pkgver=1.0
pkgrel=1
pkgdesc="Official Apollo Linux visual theme — GTK, Openbox, wallpapers"
arch=('any')
url="https://github.com/strayfodanator/apollolinux"
license=('GPL-2.0')
depends=(
    'gtk3'
    'gtk4'
    'papirus-icon-theme'
    'bibata-cursor-theme'
    'ttf-firacode-nerd'
)
optdepends=(
    'kvantum: Qt5/Qt6 theming via Kvantum engine'
    'qt5ct: Qt5 configuration tool'
    'lxappearance: GTK appearance settings'
)
source=("apollo-themes-${pkgver}.tar.gz::https://github.com/strayfodanator/apollolinux/archive/refs/heads/main.tar.gz")
sha256sums=('SKIP')

package() {
    local _src="${srcdir}/apollolinux-main/apollo-themes"

    # ── GTK3 Theme ────────────────────────────────────────────────
    install -dm755 "${pkgdir}/usr/share/themes/Apollo-Dark/gtk-3.0"
    install -dm755 "${pkgdir}/usr/share/themes/Apollo-Dark/gtk-4.0"

    install -Dm644 "${_src}/gtk/apollo-dark/gtk.css" \
        "${pkgdir}/usr/share/themes/Apollo-Dark/gtk-3.0/gtk.css"
    install -Dm644 "${_src}/gtk/apollo-dark/gtk.css" \
        "${pkgdir}/usr/share/themes/Apollo-Dark/gtk-4.0/gtk.css"
    install -Dm644 "${_src}/gtk/apollo-dark/index.theme" \
        "${pkgdir}/usr/share/themes/Apollo-Dark/index.theme"

    # ── Openbox Theme ─────────────────────────────────────────────
    install -dm755 "${pkgdir}/usr/share/themes/Apollo-Dark/openbox-3"
    install -Dm644 "${_src}/openbox/Apollo-Dark/themerc" \
        "${pkgdir}/usr/share/themes/Apollo-Dark/openbox-3/themerc"

    # ── Wallpapers ────────────────────────────────────────────────
    install -dm755 "${pkgdir}/usr/share/apollo/wallpapers"
    for wp in "${_src}/wallpapers/"*.{png,jpg,webp} 2>/dev/null; do
        [[ -f "$wp" ]] && install -Dm644 "$wp" "${pkgdir}/usr/share/apollo/wallpapers/$(basename "$wp")"
    done

    # ── Apollo Shell config defaults ──────────────────────────────
    install -dm755 "${pkgdir}/usr/share/apollo/shell"
    install -Dm644 "${srcdir}/apollolinux-main/apollo-shell/config/apollo-shell.json" \
        "${pkgdir}/usr/share/apollo/shell/apollo-shell.json"

    # ── GTK4 libadwaita color overrides ──────────────────────────
    install -dm755 "${pkgdir}/usr/share/themes/Apollo-Dark/gtk-4.0"
    cat > "${pkgdir}/usr/share/themes/Apollo-Dark/gtk-4.0/gtk.css" <<'CSS'
/* Apollo-Dark gtk4 entry point — import shared CSS */
@import url("resource:///org/gnome/Adwaita/stylesheet/base.css");
/* Override accent color */
@define-color accent_bg_color #6C8EFF;
@define-color accent_color #6C8EFF;
@define-color window_bg_color #0f1117;
@define-color window_fg_color #E8EAF0;
@define-color view_bg_color #1a1d27;
CSS

    # ── Kvantum theme ─────────────────────────────────────────────
    install -dm755 "${pkgdir}/usr/share/kvantum/Apollo-Dark"
    cat > "${pkgdir}/usr/share/kvantum/Apollo-Dark/Apollo-Dark.kvconfig" <<'KV'
[%General]
author=Apollo Linux Team
comment=Apollo Dark Qt theme
x11drag=all
alt_mnemonic=true
left_tabs=false
attach_tabs=false
remove_extra_frames=true
qt5style_colors=true
KV

    # ── Environment file for theming ──────────────────────────────
    install -dm755 "${pkgdir}/etc/environment.d"
    cat > "${pkgdir}/etc/environment.d/90-apollo-theme.conf" <<'ENV'
# Apollo Linux — Default theme environment
QT_QPA_PLATFORMTHEME=qt5ct
GTK_THEME=Apollo-Dark
XCURSOR_THEME=Bibata-Modern-Classic
XCURSOR_SIZE=24
ENV

    # ── gtkrc-2.0 (legacy GTK2 apps) ─────────────────────────────
    install -dm755 "${pkgdir}/etc/skel"
    cat > "${pkgdir}/etc/skel/.gtkrc-2.0" <<'RC'
gtk-theme-name="Apollo-Dark"
gtk-icon-theme-name="Papirus-Dark"
gtk-cursor-theme-name="Bibata-Modern-Classic"
gtk-cursor-theme-size=24
gtk-font-name="FiraCode Nerd Font 11"
gtk-toolbar-style=GTK_TOOLBAR_BOTH_HORIZ
gtk-toolbar-icon-size=GTK_ICON_SIZE_LARGE_TOOLBAR
gtk-button-images=1
gtk-menu-images=1
RC
}
